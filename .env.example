# Copy to .env and fill in values. .env is gitignored.
# IMPORTANT: every VITE_* variable is inlined into the client JS bundle and
# visible to anyone in browser DevTools. Restrict each key in Google Cloud
# Console (HTTP referrer + API restrictions) instead of relying on secrecy.

# Firebase web config (project-public; restrict in GCP)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Sheets API (restrict by HTTP referrer to your Vercel domain)
VITE_SHEETS_API_KEY=
VITE_SHEETS_SHEET_ID=

# ─────────────────────────────────────────────────────────────────────────
# SERVER-ONLY vars (Vercel Functions + crons). NOT prefixed VITE_, never sent
# to the browser. Set these in the Vercel dashboard, not in the client bundle.
# ─────────────────────────────────────────────────────────────────────────

# Google Sheets read (server side; separate key from the VITE_ one above)
# SHEETS_API_KEY=
# SHEETS_SHEET_ID=

# Firebase Admin service-account JSON (single line) for Firestore config reads
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Google Calendar auto-sync (/api/calendar-sync cron)
#   1. In Google Cloud (project wealth-architect-v2): enable the Calendar API.
#   2. Create a service account; download its JSON key (or reuse the Firebase
#      SA — it falls back to FIREBASE_SERVICE_ACCOUNT_JSON if this is unset,
#      but the Calendar API must be enabled on that project).
#   3. In Google Calendar → Settings → your calendar → "Share with specific
#      people", add the SA's client_email with "Make changes to events".
#   4. Set GOOGLE_CALENDAR_ID to that calendar's ID (your email for the
#      primary calendar, or the calendar's ID from its settings page).
# GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=
# GOOGLE_CALENDAR_ID=
# PUBLIC_SITE_URL=https://wealth-architect-delta.vercel.app
