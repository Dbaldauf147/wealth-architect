# Copy to .env and fill in values. .env is gitignored.
# IMPORTANT: every VITE_* variable is inlined into the client JS bundle and
# visible to anyone in browser DevTools. Restrict each key in Google Cloud
# Console (HTTP referrer + API restrictions) instead of relying on secrecy.

# Firebase web config (project-public; restrict in GCP)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Sheets API (restrict by HTTP referrer to your Vercel domain)
VITE_SHEETS_API_KEY=
VITE_SHEETS_SHEET_ID=
