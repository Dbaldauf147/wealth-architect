{
  "crons": [
    {
      "path": "/api/weekly-summary",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/payment-reminder",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/calendar-sync",
      "schedule": "30 14 * * *"
    }
  ],
  "headers": [
    {
      "source": "/version.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ]
}
