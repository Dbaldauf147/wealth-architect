// Firestore Security Rules for the wealth-architecht project.
//
// State of the codebase: single-user app with no auth. The website writes
// the user's category rules and per-transaction overrides to a single doc
// at /config/default so the Vercel weekly-summary Function can read them
// and apply the same categorization view as the website.
//
// The /config/default doc allows public read+write because there is no
// auth wired in yet. When auth lands, tighten this to:
//   match /config/default {
//     allow read, write: if request.auth != null && request.auth.uid == 'YOUR_UID';
//   }
//
// All other paths remain locked so accidental writes to other collections
// can't happen.
//
// To deploy: paste into Firebase Console → Firestore Database → Rules → Publish.
// Alternatively, install the Firebase CLI and run:
//   firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /config/default {
      allow read, write: if true;
    }
    match /budgets/{doc=**} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
