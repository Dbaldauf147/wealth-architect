// Firestore Security Rules for the wealth-architecht project.
//
// State of the codebase: Firebase SDK is initialized (src/firebase.js) but no
// Firestore reads or writes are wired up anywhere. To keep the database
// inaccessible until a real auth flow exists, this rule denies every request.
//
// To loosen later: replace the inner match with per-collection rules that
// require request.auth.uid to match a document field, e.g.:
//   match /users/{uid}/{doc=**} {
//     allow read, write: if request.auth != null && request.auth.uid == uid;
//   }
//
// To deploy: paste into Firebase Console → Firestore Database → Rules → Publish.
// Alternatively, install the Firebase CLI and run:
//   firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
